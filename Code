<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#000000">
    <title>Feature World: Infinite Chaos Edition</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            touch-action: none;
            -webkit-tap-highlight-color: transparent;
        }
        
        body {
            overflow: hidden;
            background: #000;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            user-select: none;
            -webkit-user-select: none;
            position: fixed;
            width: 100%;
            height: 100%;
        }
        
        #canvas-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
        }
        
        /* Loading Screen */
        #loading-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #1a1a2e, #16213e, #0f3460);
            z-index: 1000;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: white;
            transition: opacity 0.5s;
        }
        
        #loading-screen.hidden {
            opacity: 0;
            pointer-events: none;
        }
        
        .loader {
            width: 60px;
            height: 60px;
            border: 4px solid rgba(255,255,255,0.1);
            border-top-color: #ff006e;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-bottom: 20px;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        /* Share Modal */
        #share-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.95);
            z-index: 600;
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        
        #share-modal.show {
            display: flex;
        }
        
        .share-content {
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            border-radius: 20px;
            padding: 30px;
            text-align: center;
            max-width: 90%;
            border: 2px solid #8338ec;
        }
        
        #qrcode {
            width: 200px;
            height: 200px;
            margin: 20px auto;
            background: white;
            padding: 10px;
            border-radius: 10px;
        }
        
        .share-link {
            background: rgba(255,255,255,0.1);
            padding: 15px;
            border-radius: 10px;
            margin: 15px 0;
            font-size: 12px;
            word-break: break-all;
            color: #3a86ff;
        }
        
        .share-btn {
            background: linear-gradient(135deg, #8338ec, #3a86ff);
            border: none;
            color: white;
            padding: 15px 30px;
            border-radius: 25px;
            font-size: 16px;
            cursor: pointer;
            margin: 5px;
            width: 100%;
        }
        
        /* Install Prompt */
        #install-prompt {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%) translateY(200%);
            background: linear-gradient(135deg, #ff006e, #8338ec);
            color: white;
            padding: 15px 25px;
            border-radius: 50px;
            z-index: 300;
            transition: transform 0.3s;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 14px;
            box-shadow: 0 4px 20px rgba(131, 56, 236, 0.5);
        }
        
        #install-prompt.show {
            transform: translateX(-50%) translateY(0);
        }
        
        /* UI Elements */
        #notification {
            position: fixed;
            top: 80px;
            left: 50%;
            transform: translateX(-50%) translateY(-100px);
            background: linear-gradient(135deg, #ff006e, #8338ec, #3a86ff);
            color: white;
            padding: 15px 30px;
            border-radius: 50px;
            font-size: 16px;
            font-weight: bold;
            z-index: 100;
            transition: transform 0.3s;
            pointer-events: none;
            max-width: 90%;
            text-align: center;
        }
        
        #notification.show {
            transform: translateX(-50%) translateY(0);
        }
        
        #settings-btn, #share-btn-header {
            position: fixed;
            top: 20px;
            width: 50px;
            height: 50px;
            background: rgba(0,0,0,0.7);
            border: 2px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            color: white;
            font-size: 24px;
            cursor: pointer;
            z-index: 150;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(10px);
        }
        
        #settings-btn { left: 20px; }
        #share-btn-header { right: 20px; }
        
        #settings-menu {
            position: fixed;
            top: 80px;
            left: 20px;
            background: rgba(0,0,0,0.95);
            border: 2px solid #8338ec;
            border-radius: 15px;
            padding: 10px;
            z-index: 160;
            display: none;
            flex-direction: column;
            gap: 10px;
            backdrop-filter: blur(10px);
        }
        
        #settings-menu.show { display: flex; }
        
        .settings-option {
            background: rgba(255,255,255,0.1);
            border: none;
            color: white;
            padding: 12px 20px;
            border-radius: 10px;
            cursor: pointer;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        #skills-panel, #skins-panel {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0);
            background: rgba(0,0,0,0.98);
            border: 3px solid #8338ec;
            border-radius: 20px;
            padding: 20px;
            z-index: 500;
            width: 95vw;
            max-width: 500px;
            max-height: 85vh;
            display: flex;
            flex-direction: column;
            transition: transform 0.3s ease-out;
            backdrop-filter: blur(20px);
        }
        
        #skins-panel { border-color: #ff006e; }
        #skills-panel.show, #skins-panel.show { transform: translate(-50%, -50%) scale(1); }
        
        #skills-backdrop {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.7);
            z-index: 499;
            display: none;
            opacity: 0;
            transition: opacity 0.3s;
            backdrop-filter: blur(5px);
        }
        
        #skills-backdrop.show { display: block; opacity: 1; }
        
        #skills-panel h2, #skins-panel h2 {
            color: #ff006e;
            text-align: center;
            margin-bottom: 15px;
            margin-top: 10px;
            font-size: 24px;
        }
        
        #skills-list, #skins-grid {
            overflow-y: auto;
            flex: 1;
            padding-right: 5px;
            -webkit-overflow-scrolling: touch;
        }
        
        #skins-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            padding: 10px;
        }
        
        @media (min-width: 400px) {
            #skins-grid { grid-template-columns: repeat(3, 1fr); }
        }
        
        .skin-card {
            background: rgba(255,255,255,0.05);
            border: 2px solid rgba(255,255,255,0.2);
            border-radius: 15px;
            padding: 15px 10px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            position: relative;
        }
        
        .skin-card:active { transform: scale(0.95); }
        .skin-card.locked { opacity: 0.5; filter: grayscale(1); }
        .skin-card.selected { border-color: #4CAF50; box-shadow: 0 0 15px rgba(76, 175, 80, 0.5); }
        .skin-card.hidden-skin:not(.locked) { 
            border-color: #ffd700; 
            animation: glow 2s infinite;
            background: linear-gradient(135deg, rgba(255,215,0,0.1), rgba(255,140,0,0.1));
        }
        
        @keyframes glow {
            0%, 100% { box-shadow: 0 0 5px #ffd700; }
            50% { box-shadow: 0 0 20px #ffd700, 0 0 30px #ff8c00; }
        }
        
        .skin-icon { font-size: 40px; margin-bottom: 8px; }
        .skin-name { color: white; font-size: 12px; font-weight: bold; }
        .skin-rarity { font-size: 9px; margin-top: 5px; padding: 2px 6px; border-radius: 8px; display: inline-block; text-transform: uppercase; }
        .rarity-common { background: #888; color: white; }
        .rarity-rare { background: #3a86ff; color: white; }
        .rarity-epic { background: #8338ec; color: white; }
        .rarity-legendary { background: linear-gradient(90deg, #ffd700, #ff8c00); color: black; }
        .rarity-secret { background: linear-gradient(90deg, #ff006e, #8338ec); color: white; }
        
        .skill-item {
            margin: 10px 0;
            color: white;
            background: rgba(255,255,255,0.05);
            padding: 15px;
            border-radius: 10px;
        }
        
        .skill-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }
        
        .skill-toggle {
            background: #444;
            border: none;
            color: white;
            padding: 5px 15px;
            border-radius: 15px;
            cursor: pointer;
            font-size: 12px;
        }
        
        .skill-toggle.active { background: #4CAF50; }
        .skill-toggle.inactive { background: #f44336; }
        
        .skill-bar {
            width: 100%;
            height: 20px;
            background: rgba(255,255,255,0.1);
            border-radius: 10px;
            overflow: hidden;
        }
        
        .skill-fill {
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: bold;
            transition: width 0.5s;
        }
        
        .close-panel {
            position: absolute;
            top: 10px;
            right: 15px;
            background: rgba(255,255,255,0.1);
            border: 2px solid rgba(255,255,255,0.3);
            color: white;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            font-size: 20px;
            cursor: pointer;
            z-index: 501;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        #active-boosts {
            position: fixed;
            top: 80px;
            right: 10px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            z-index: 100;
            max-width: 150px;
        }
        
        .boost-indicator {
            background: rgba(0,0,0,0.8);
            border: 2px solid;
            border-radius: 12px;
            padding: 8px 12px;
            color: white;
            font-size: 11px;
            display: flex;
            align-items: center;
            gap: 8px;
            backdrop-filter: blur(10px);
        }
        
        .malus-indicator {
            background: rgba(50, 0, 0, 0.9);
            border-color: #ff4444;
            animation: pulse 1s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }
        
        #parkour-indicator {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: linear-gradient(135deg, #ffd700, #ff8c00);
            color: black;
            padding: 20px 40px;
            border-radius: 20px;
            font-size: 22px;
            font-weight: bold;
            z-index: 90;
            opacity: 0;
            transition: opacity 0.5s;
            pointer-events: none;
            text-align: center;
        }
        
        #parkour-indicator.show { opacity: 1; }
        
        /* Mobile-optimized Controls */
        #joystick-zone {
            position: fixed;
            left: 20px;
            bottom: 20px;
            width: 140px;
            height: 140px;
            background: rgba(255,255,255,0.08);
            border: 3px solid rgba(255,255,255,0.2);
            border-radius: 50%;
            z-index: 50;
            touch-action: none;
        }
        
        #joystick-knob {
            position: absolute;
            width: 55px;
            height: 55px;
            background: linear-gradient(135deg, #ff006e, #8338ec);
            border: 3px solid rgba(255,255,255,0.5);
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            pointer-events: none;
        }
        
        #joystick-knob.active {
            background: linear-gradient(135deg, #ff4d00, #ff006e);
            transform: translate(-50%, -50%) scale(0.9);
        }
        
        #jump-btn {
            position: fixed;
            right: 20px;
            bottom: 20px;
            width: 90px;
            height: 90px;
            background: linear-gradient(135deg, #ff006e, #ff4d00);
            border: 3px solid rgba(255,255,255,0.5);
            border-radius: 50%;
            color: white;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            z-index: 50;
            box-shadow: 0 4px 20px rgba(255,0,110,0.4);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        #jump-btn:active { transform: scale(0.95); }
        
        #instructions {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #1a1a2e, #16213e, #0f3460);
            color: white;
            padding: 40px 20px;
            z-index: 200;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            overflow-y: auto;
        }
        
        #instructions h1 {
            color: #ff006e;
            margin-bottom: 20px;
            font-size: 28px;
            text-shadow: 0 0 20px rgba(255,0,110,0.5);
        }
        
        .feature-list {
            text-align: left;
            margin: 20px 0;
            font-size: 16px;
            line-height: 1.8;
        }
        
        .feature-list li {
            margin: 10px 0;
            list-style: none;
        }
        
        #start-btn {
            margin-top: 30px;
            padding: 18px 50px;
            background: linear-gradient(135deg, #8338ec, #3a86ff);
            color: white;
            border: none;
            border-radius: 50px;
            font-size: 20px;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 4px 20px rgba(131,56,236,0.5);
            transition: transform 0.2s;
        }
        
        #start-btn:active { transform: scale(0.95); }
        
        .hidden { display: none !important; }
        
        #chrome-notification {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0);
            background: linear-gradient(135deg, #c0c0c0, #ffffff, #c0c0c0);
            color: black;
            padding: 30px;
            border-radius: 30px;
            font-size: 24px;
            font-weight: bold;
            z-index: 400;
            transition: transform 0.5s;
            text-align: center;
            max-width: 90%;
        }
        
        #chrome-notification.show { transform: translate(-50%, -50%) scale(1); }
        
        /* Performance indicator */
        #fps-counter {
            position: fixed;
            top: 80px;
            left: 20px;
            background: rgba(0,0,0,0.7);
            color: #0f0;
            padding: 5px 10px;
            border-radius: 5px;
            font-size: 12px;
            font-family: monospace;
            z-index: 50;
            display: none;
        }
        
        /* Orientation warning */
        #orientation-warning {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #000;
            color: white;
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            text-align: center;
            padding: 20px;
        }
        
        @media (orientation: portrait) and (max-height: 500px) {
            #orientation-warning { display: flex; }
        }
        
        .fullscreen-btn {
            position: fixed;
            bottom: 130px;
            right: 20px;
            width: 50px;
            height: 50px;
            background: rgba(0,0,0,0.7);
            border: 2px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            color: white;
            font-size: 20px;
            cursor: pointer;
            z-index: 50;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>
<body>
    <!-- Loading Screen -->
    <div id="loading-screen">
        <div class="loader"></div>
        <div>Chargement...</div>
        <div style="font-size: 12px; margin-top: 10px; opacity: 0.7;">Préparation du monde infini</div>
    </div>

    <!-- Orientation Warning -->
    <div id="orientation-warning">
        <div style="font-size: 60px; margin-bottom: 20px;">📱</div>
        <h2>Tournez votre téléphone</h2>
        <p>Pour une meilleure expérience, utilisez le mode paysage</p>
    </div>

    <!-- Share Modal -->
    <div id="share-modal">
        <div class="share-content">
            <h2 style="color: #ff006e; margin-bottom: 20px;">🌐 Partager le jeu</h2>
            <div id="qrcode"></div>
            <div class="share-link" id="share-url">https://featureworld.game</div>
            <button class="share-btn" onclick="copyLink()">📋 Copier le lien</button>
            <button class="share-btn" onclick="shareNative()" style="background: linear-gradient(135deg, #ff006e, #8338ec);">
                📤 Partager
            </button>
            <button class="share-btn" onclick="closeShare()" style="background: #444;">❌ Fermer</button>
        </div>
    </div>

    <!-- Install Prompt -->
    <div id="install-prompt" onclick="installApp()">
        <span>📲</span>
        <span>Installer Feature World</span>
    </div>

    <div id="canvas-container"></div>
    
    <button id="settings-btn" class="hidden">⚙️</button>
    <button id="share-btn-header" class="hidden" onclick="openShare()">🔗</button>
    <button id="fullscreen-btn" class="hidden fullscreen-btn" onclick="toggleFullscreen()">⛶</button>
    
    <div id="settings-menu">
        <button class="settings-option" id="menu-main-btn">🏠 Menu Principal</button>
        <button class="settings-option" id="menu-skills-btn">📊 Compétences</button>
        <button class="settings-option" id="menu-skins-btn">🎨 Skins</button>
        <button class="settings-option" id="menu-share-btn">🔗 Partager</button>
        <button class="settings-option" id="menu-install-btn" style="display:none;">📲 Installer</button>
        <button class="settings-option" id="menu-close-btn">❌ Fermer</button>
    </div>
    
    <div id="skills-backdrop" onclick="closeAllPanels()"></div>
    
    <div id="skills-panel">
        <button class="close-panel" onclick="closeAllPanels()">×</button>
        <h2>📊 Compétences</h2>
        <div id="skills-list"></div>
    </div>

    <div id="skins-panel">
        <button class="close-panel" onclick="closeAllPanels()">×</button>
        <h2>🎨 Skins</h2>
        <div id="skins-grid"></div>
    </div>
    
    <div id="notification"></div>
    <div id="active-boosts"></div>
    <div id="parkour-indicator">🏁 ZONE PARKOUR 🏁</div>
    <div id="fps-counter">FPS: 60</div>
    
    <div id="chrome-notification">
        ✨ TRANSFORMATION CHROMATIQUE ! ✨<br>
        <small>Toutes les compétences au maximum !</small>
    </div>
    
    <div id="joystick-zone" class="hidden">
        <div id="joystick-knob"></div>
    </div>
    
    <button id="jump-btn" class="hidden">SAUT</button>
    
    <div id="instructions">
        <h1>🎮 Feature World</h1>
        <div style="font-size: 18px; color: #8338ec; margin-bottom: 20px;">Infinite Chaos Edition</div>
        
        <ul class="feature-list">
            <li>🕹️ <strong>Joystick</strong> - Déplacez-vous</li>
            <li>👆 <strong>Bouton SAUT</strong> - Sautez</li>
            <li>💎 <strong>Collectez</strong> des boosts</li>
            <li>🎨 <strong>Trouvez</strong> les skins cachés</li>
            <li>🏆 <strong>Complétez</strong> les parkours</li>
        </ul>
        
        <div style="font-size: 14px; opacity: 0.8; margin: 20px 0;">
            📱 Optimisé pour mobile<br>
            🌐 Jouez n'importe où, n'importe quand
        </div>
        
        <button id="start-btn">▶ JOUER</button>
        
        <div style="margin-top: 30px; font-size: 12px; opacity: 0.6;">
            <button onclick="openShare()" style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.3); color: white; padding: 10px 20px; border-radius: 20px; cursor: pointer;">
                🔗 Partager avec des amis
            </button>
        </div>
    </div>

    <!-- QRCode.js library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script>
        // Game State
        const state = {
            isPlaying: false,
            isJumping: false,
            speed: 0.15,
            normalSpeed: 0.15,
            baseSpeed: 0.12,
            jumpForce: 0.3,
            baseJumpForce: 0.25,
            rotationSpeed: 0.03,
            characterRotation: 0,
            currentScale: 1,
            
            skills: {
                speed: { level: 1, max: 100, color: '#ff6b6b', enabled: true },
                jump: { level: 1, max: 100, color: '#ffd93d', enabled: true },
                invisible: { level: 1, max: 100, color: '#6bcf7f', enabled: true },
                size: { level: 1, max: 100, color: '#c084fc', enabled: true }
            },
            
            isChrome: false,
            inParkour: false,
            activeEffects: new Map(),
            currentSkin: 'default',
            unlockedSkins: ['default'],
            hiddenSkinsFound: new Set()
        };

        const SKINS = {
            default: { name: 'Classique', icon: '🤎', rarity: 'common', bodyColor: 0x8B4513, headColor: 0x32CD32, metalness: 0, roughness: 0.8, hidden: false, description: 'Le skin de base' },
            golden: { name: 'Golden', icon: '🏆', rarity: 'legendary', bodyColor: 0xFFD700, headColor: 0xFFA500, metalness: 0.8, roughness: 0.2, hidden: true, description: 'Zone parkour' },
