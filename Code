            updateSkillsDisplay();
            applySkillEffects();
            showNotification(`${skill.enabled ? '✅' : '❌'} ${skillName}`, skill.enabled ? `linear-gradient(90deg,${skill.color},#333)` : '#666');
        }

        function openSkills() {
            document.getElementById('skills-panel').classList.add('show');
            document.getElementById('skills-backdrop').classList.add('show');
            document.getElementById('skins-panel').classList.remove('show');
            updateSkillsDisplay();
        }

        function openSkins() {
            document.getElementById('skins-panel').classList.add('show');
            document.getElementById('skills-backdrop').classList.add('show');
            document.getElementById('skills-panel').classList.remove('show');
            updateSkinsDisplay();
        }

        function closeAllPanels() {
            document.getElementById('skills-panel').classList.remove('show');
            document.getElementById('skins-panel').classList.remove('show');
            document.getElementById('skills-backdrop').classList.remove('show');
            document.getElementById('settings-menu').classList.remove('show');
        }

        function toggleSettings() {
            document.getElementById('settings-menu').classList.toggle('show');
        }

        function getGroundHeight(x, z, currentY, velocityY) {
            const terrainH = getHeightAt(x, z);
            let candidateHeight = terrainH;
            for (const platform of parkourPlatforms) {
                const dx = x - platform.position.x, dz = z - platform.position.z;
                const dist = Math.sqrt(dx * dx + dz * dz);
                if (dist < platform.userData.radius) {
                    const platformTop = platform.userData.topY;
                    const isFalling = velocityY <= 0;
                    if ((currentY >= platformTop - 0.5 && isFalling) || (Math.abs(currentY - platformTop) < 2 && Math.abs(velocityY) < 0.1)) {
                        if (platformTop > candidateHeight) candidateHeight = platformTop;
                    }
                }
            }
            return candidateHeight + (0.7 * state.currentScale);
        }

        function checkCollisions() {
            const charPos = character.mesh.position;
            
            // Collectibles
            for (let i = collectibles.length - 1; i >= 0; i--) {
                const obj = collectibles[i];
                if (!obj || !obj.userData || obj.userData.collected) continue;
                const hitboxSize = 4.5 * state.currentScale;
                const dy = Math.abs(charPos.y - obj.position.y);
                const horizontalDist = Math.sqrt(Math.pow(charPos.x - obj.position.x, 2) + Math.pow(charPos.z - obj.position.z, 2));
                
                if (horizontalDist < hitboxSize && dy < 4 * state.currentScale) {
                    obj.userData.collected = true;
                    collectedBoosts.add(obj.userData.id);
                    const effect = obj.userData.type;
                    
                    if (effect.isSkill) {
                        showNotification(`${effect.desc}`, `linear-gradient(135deg,#${effect.color.toString(16).padStart(6,'0')},#333)`);
                        addSkillLevel(effect.skill, 1);
                    } else {
                        showNotification(`${effect.desc}`, `linear-gradient(135deg,#${effect.color.toString(16).padStart(6,'0')},#ff0000)`);
                        const endTime = Date.now() + effect.duration;
                        state.activeEffects.set(effect.effect, { endTime, type: effect });
                        setTimeout(() => {
                            state.activeEffects.delete(effect.effect);
                            recalculateCurrentStats();
                        }, effect.duration);
                        recalculateCurrentStats();
                    }
                    scene.remove(obj);
                    collectibles.splice(i, 1);
                }
            }
            
            // Skin orbs
            for (let i = hiddenSkinOrbs.length - 1; i >= 0; i--) {
                const orb = hiddenSkinOrbs[i];
                if (!orb || !orb.userData) continue;
                if (charPos.distanceTo(orb.position) < 3) {
                    unlockSkin(orb.userData.skinId);
                    scene.remove(orb);
                    hiddenSkinOrbs.splice(i, 1);
                }
            }
            
            // Parkour
            parkourZones.forEach(zone => {
                if (zone.collected) return;
                if (charPos.distanceTo(new THREE.Vector3(zone.finalX, zone.finalY + 4, zone.finalZ)) < 8) {
                    zone.collected = true;
                    if (zone.rewardOrb) scene.remove(zone.rewardOrb);
                    if (!state.unlockedSkins.includes('golden')) unlockSkin('golden');
                    showNotification('🏆 +5 NIVEAUX!', 'linear-gradient(135deg,#ffd700,#ff8c00)');
                    Object.keys(state.skills).forEach(skill => addSkillLevel(skill, 5));
                }
            });
        }

        function updateCharacter() {
            const char = character.mesh;
            let moved = false;
            
            if (joystick.active) {
                const rotationInput = joystick.deltaX / joystick.maxRadius;
                state.characterRotation -= rotationInput * state.rotationSpeed * 2;
                
                const moveInput = -joystick.deltaY / joystick.maxRadius;
                if (Math.abs(moveInput) > 0.1) {
                    const moveSpeed = state.speed * Math.abs(moveInput);
                    if (moveInput > 0) {
                        char.position.x -= Math.sin(state.characterRotation) * moveSpeed;
                        char.position.z -= Math.cos(state.characterRotation) * moveSpeed;
                    } else {
                        char.position.x += Math.sin(state.characterRotation) * moveSpeed;
                        char.position.z += Math.cos(state.characterRotation) * moveSpeed;
                    }
                    moved = true;
                }
            }
            
            char.rotation.y = state.characterRotation;
            
            if (state.isJumping && isGrounded) {
                jumpVelocity = state.jumpForce;
                isGrounded = false;
                state.isJumping = false;
            }
            
            if (!isGrounded) jumpVelocity -= 0.015;
            
            let newY = char.position.y;
            if (!isGrounded || jumpVelocity > 0) newY += jumpVelocity;
            
            const groundY = getGroundHeight(char.position.x, char.position.z, char.position.y, jumpVelocity);
            
            if (newY <= groundY) {
                if (!isGrounded && jumpVelocity < 0) {
                    isGrounded = true;
                    jumpVelocity = 0;
                }
                newY = groundY;
                isGrounded = true;
            } else {
                isGrounded = false;
            }
            
            char.position.y = newY;
            
            if (moved && isGrounded) {
                walkCycle += 0.15;
                character.leftArmGroup.rotation.x = Math.sin(walkCycle) * 0.6;
                character.rightArmGroup.rotation.x = Math.sin(walkCycle + Math.PI) * 0.6;
                character.leftLegGroup.rotation.x = Math.sin(walkCycle + Math.PI) * 0.6;
                character.rightLegGroup.rotation.x = Math.sin(walkCycle) * 0.6;
            } else {
                character.leftArmGroup.rotation.x *= 0.85;
                character.rightArmGroup.rotation.x *= 0.85;
                character.leftLegGroup.rotation.x *= 0.85;
                character.rightLegGroup.rotation.x *= 0.85;
            }
            
            const camDistance = Math.min(14 * state.currentScale, 30);
            const camHeight = Math.min(10 * state.currentScale, 20);
            const targetPos = char.position.clone();
            targetPos.x += Math.sin(state.characterRotation) * camDistance;
            targetPos.z += Math.cos(state.characterRotation) * camDistance;
            targetPos.y += camHeight;
            camera.position.lerp(targetPos, 0.08);
            camera.lookAt(char.position.x, char.position.y + 2 * Math.min(state.currentScale, 3), char.position.z);
        }

        function updateCollectibles() {
            const time = Date.now();
            collectibles.forEach((obj, i) => {
                if (!obj) return;
                obj.position.y = obj.userData.originalY + Math.sin(time * obj.userData.bobSpeed + i) * 0.4;
                obj.rotation.y += obj.userData.rotationSpeed;
            });
            for (let i = collectibles.length - 1; i >= 0; i--) {
                if (collectibles[i] && collectibles[i].position.distanceTo(character.mesh.position) > 150) {
                    scene.remove(collectibles[i]);
                    collectibles.splice(i, 1);
                }
            }
        }

        function updateHiddenSkins() {
            const time = Date.now();
            hiddenSkinOrbs.forEach(orb => {
                orb.rotation.y += orb.userData.rotationSpeed;
                orb.rotation.z += orb.userData.rotationSpeed * 0.5;
                if (orb.userData.floating) orb.position.y = orb.userData.originalY + Math.sin(time * 0.001) * 2;
                else orb.position.y = orb.userData.originalY + Math.sin(time * 0.002) * 0.5;
                if (orb.userData.aura) orb.userData.aura.rotation.z += 0.02;
            });
        }

        function updateClouds() {
            clouds.children.forEach(cloud => {
                cloud.position.x += 0.015;
                if (cloud.position.x > 200) cloud.position.x = -200;
            });
        }

        function updateActiveBoosts() {
            const container = document.getElementById('active-boosts');
            container.innerHTML = '';
            state.activeEffects.forEach((data, effectType) => {
                const remaining = Math.ceil((data.endTime - Date.now()) / 1000);
                if (remaining > 0) {
                    const boost = boostTypes.find(b => b.effect === effectType);
                    const div = document.createElement('div');
                    div.className = 'boost-indicator malus-indicator';
                    div.style.borderColor = '#' + boost.color.toString(16).padStart(6, '0');
                    const icons = { slow: '🐌', tiny: '🔽', giant: '🔼' };
                    div.innerHTML = `<span style="font-size:16px">${icons[effectType]}</span><div style="flex:1"><div style="font-weight:bold">${boost.name}</div></div><span>${remaining}s</span>`;
                    container.appendChild(div);
                }
            });
        }

        let lastCollectibleSpawn = 0, lastTerrainUpdate = 0, frameCount = 0;

        function animate() {
            requestAnimationFrame(animate);
            if (!state.isPlaying) return;
            
            const now = Date.now();
            
            // Update terrain (throttled)
            if (now - lastTerrainUpdate > 100) {
                lastTerrainUpdate = now;
                const px = character.mesh.position.x, pz = character.mesh.position.z;
                const gridSize = 200 / 128;
                const snapX = Math.floor(px / gridSize) * gridSize;
                const snapZ = Math.floor(pz / gridSize) * gridSize;
                if (Math.abs(terrainMesh.position.x - snapX) > 60 || Math.abs(terrainMesh.position.z - snapZ) > 60) {
                    terrainMesh.position.x = snapX;
                    terrainMesh.position.z = snapZ;
                    const vertices = terrainMesh.geometry.attributes.position.array;
                    for (let i = 0; i < vertices.length; i += 3) {
                        vertices[i + 2] = getHeightAt(vertices[i] + snapX, vertices[i + 1] + snapZ);
                    }
                    terrainMesh.geometry.attributes.position.needsUpdate = true;
                    terrainMesh.geometry.computeVertexNormals();
                }
            }
            
            updateCharacter();
            updateCollectibles();
            updateClouds();
            updateHiddenSkins();
            checkCollisions();
            updateActiveBoosts();
            
            if (now - lastCollectibleSpawn > 6000 && collectibles.length < 15) {
                spawnCollectibles();
                lastCollectibleSpawn = now;
            }
            
            renderer.render(scene, camera);
            frameCount++;
        }

        // Setup Joystick
        function setupJoystick() {
            const zone = document.getElementById('joystick-zone');
            const knob = document.getElementById('joystick-knob');
            
            const handleStart = (e) => {
                e.preventDefault();
                joystick.active = true;
                knob.classList.add('active');
                updateJoystickPosition(e);
            };
            
            const handleMove = (e) => {
                if (!joystick.active) return;
                e.preventDefault();
                updateJoystickPosition(e);
            };
            
            const handleEnd = (e) => {
                e.preventDefault();
                joystick.active = false;
                joystick.deltaX = 0;
                joystick.deltaY = 0;
                knob.classList.remove('active');
                knob.style.left = '50%';
                knob.style.top = '50%';
                knob.style.transform = 'translate(-50%, -50%)';
            };
            
            const updateJoystickPosition = (e) => {
                const rect = zone.getBoundingClientRect();
                const centerX = rect.left + rect.width / 2;
                const centerY = rect.top + rect.height / 2;
                const clientX = e.touches ? e.touches[0].clientX : e.clientX;
                const clientY = e.touches ? e.touches[0].clientY : e.clientY;
                let deltaX = clientX - centerX;
                let deltaY = clientY - centerY;
                const distance = Math.sqrt(deltaX * deltaX + deltaY * deltaY);
                if (distance > joystick.maxRadius) {
                    const ratio = joystick.maxRadius / distance;
                    deltaX *= ratio;
                    deltaY *= ratio;
                }
                joystick.deltaX = deltaX;
                joystick.deltaY = deltaY;
                knob.style.left = (50 + (deltaX / rect.width) * 100) + '%';
                knob.style.top = (50 + (deltaY / rect.height) * 100) + '%';
                knob.style.transform = 'translate(-50%, -50%)';
            };
            
            zone.addEventListener('touchstart', handleStart, { passive: false });
            zone.addEventListener('touchmove', handleMove, { passive: false });
            zone.addEventListener('touchend', handleEnd, { passive: false });
            zone.addEventListener('touchcancel', handleEnd, { passive: false });
            zone.addEventListener('mousedown', handleStart);
            document.addEventListener('mousemove', handleMove);
            document.addEventListener('mouseup', handleEnd);
        }

        function setupControls() {
            setupJoystick();
            
            document.getElementById('jump-btn').addEventListener('touchstart', (e) => { 
                e.preventDefault(); 
                if (isGrounded) state.isJumping = true; 
            }, { passive: false });
            
            document.getElementById('jump-btn').addEventListener('mousedown', (e) => { 
                e.preventDefault(); 
                if (isGrounded) state.isJumping = true; 
            });
            
            document.addEventListener('keydown', (e) => {
                if (!state.isPlaying) return;
                switch(e.key) {
                    case 'ArrowLeft': case 'a': case 'A': joystick.deltaX = -joystick.maxRadius; joystick.active = true; break;
                    case 'ArrowRight': case 'd': case 'D': joystick.deltaX = joystick.maxRadius; joystick.active = true; break;
                    case 'ArrowUp': case 'w': case 'W': joystick.deltaY = -joystick.maxRadius; joystick.active = true; break;
                    case 'ArrowDown': case 's': case 'S': joystick.deltaY = joystick.maxRadius; joystick.active = true; break;
                    case ' ': if (isGrounded) state.isJumping = true; break;
                }
            });
            
            document.addEventListener('keyup', (e) => {
                if (['ArrowLeft','a','A','ArrowRight','d','D','ArrowUp','w','W','ArrowDown','s','S'].includes(e.key)) {
                    joystick.active = false;
                    joystick.deltaX = 0;
                    joystick.deltaY = 0;
                    const knob = document.getElementById('joystick-knob');
                    knob.style.left = '50%';
                    knob.style.top = '50%';
                    knob.style.transform = 'translate(-50%, -50%)';
                }
            });
            
            document.getElementById('settings-btn').addEventListener('click', toggleSettings);
            document.getElementById('menu-main-btn').addEventListener('click', () => location.reload());
            document.getElementById('menu-skills-btn').addEventListener('click', () => { toggleSettings(); openSkills(); });
            document.getElementById('menu-skins-btn').addEventListener('click', () => { toggleSettings(); openSkins(); });
            document.getElementById('menu-share-btn').addEventListener('click', () => { toggleSettings(); openShare(); });
            document.getElementById('menu-install-btn').addEventListener('click', () => { toggleSettings(); installApp(); });
            document.getElementById('menu-close-btn').addEventListener('click', toggleSettings);
            
            document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAllPanels(); });
        }

        // Start Game
        document.getElementById('start-btn').addEventListener('click', () => {
            // Hide loading
            document.getElementById('loading-screen').classList.add('hidden');
            document.getElementById('instructions').classList.add('hidden');
            document.getElementById('joystick-zone').classList.remove('hidden');
            document.getElementById('jump-btn').classList.remove('hidden');
            document.getElementById('settings-btn').classList.remove('hidden');
            document.getElementById('share-btn-header').classList.remove('hidden');
            document.getElementById('fullscreen-btn').classList.remove('hidden');
            
            state.isPlaying = true;
            
            generateSeamlessTerrain();
            character = createCharacter();
            scene.add(character.mesh);
            clouds = createClouds();
            spawnParkourZones();
            spawnHiddenSkins();
            spawnCollectibles();
            applySkillEffects();
            recalculateCurrentStats();
            
            camera.position.set(0, 15, 25);
            
            // Try fullscreen on mobile
            if (/iPhone|iPad|iPod|Android/i.test(navigator.userAgent)) {
                setTimeout(() => {
                    document.documentElement.requestFullscreen().catch(() => {});
                }, 1000);
            }
        });

        // Initialize
        setupControls();
        animate();

        // Handle resize
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        // Prevent zoom on double tap
        let lastTouchEnd = 0;
        document.addEventListener('touchend', (e) => {
            const now = Date.now();
            if (now - lastTouchEnd <= 300) e.preventDefault();
            lastTouchEnd = now;
        }, { passive: false });

        // Prevent context menu
        document.addEventListener('contextmenu', e => e.preventDefault());
    </script>
