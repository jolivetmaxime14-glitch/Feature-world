        function addSkillLevel(skillName, levels) {
            const skill = state.skills[skillName];
            if (!skill || skill.level >= skill.max) return;
            const oldLevel = skill.level;
            skill.level = Math.min(skill.level + levels, skill.max);
            if (skill.level > oldLevel) {
                const names = { speed: '⚡ Vitesse', jump: '🦘 Saut', invisible: '👻 Invisibilité', size: '📏 Taille' };
                showNotification(`+${skill.level - oldLevel} ${names[skillName]}!`, `linear-gradient(90deg,${skill.color},#fff)`);
                updateSkillsDisplay();
                applySkillEffects();
                if (skillName === 'speed' && skill.level >= 50) unlockSkin('cyber');
                if (skillName === 'invisible' && skill.level >= 50) unlockSkin('ninja');
                if (Object.values(state.skills).every(s => s.level >= s.max) && !state.isChrome) {
                    unlockSkin('chrome');
                    changeSkin('chrome');
                }
            }
        }

        function applySkillEffects() {
            state.baseSpeed = 0.12 + (state.skills.speed.enabled ? (state.skills.speed.level - 1) * 0.002 : 0);
            state.baseJumpForce = 0.25 + (state.skills.jump.enabled ? (state.skills.jump.level - 1) * 0.003 : 0);
            recalculateCurrentStats();
        }

        function recalculateCurrentStats() {
            let scale = 1;
            if (state.activeEffects.has('tiny')) scale = 0.3;
            else if (state.activeEffects.has('giant')) scale = 3.0;
            if (state.skills.size.enabled) scale += (state.skills.size.level - 1) * 0.01;
            scale = Math.max(0.2, Math.min(scale, 5.0));
            state.currentScale = scale;
            character.mesh.scale.setScalar(scale);
            state.jumpForce = state.baseJumpForce * Math.max(0.5, scale);
            let speed = state.baseSpeed;
            if (state.activeEffects.has('slow')) speed *= 0.4;
            speed *= Math.sqrt(scale);
            state.normalSpeed = state.speed = speed;
        }

